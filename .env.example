# ──────────────────────────────────────────────────────────────
# DowaLabs Membership Website — Environment Variables
# Copy this file to ".env.local" for local dev, and set the same
# variables in the Vercel project dashboard for production.
# ──────────────────────────────────────────────────────────────

# MongoDB Atlas connection string.
# Example: mongodb+srv://user:pass@cluster0.xxxxx.mongodb.net/dowalabs?retryWrites=true&w=majority
MONGODB_URI=

# Secret used to sign JWT session cookies. Use a long random string.
# Generate one with:  openssl rand -base64 48
JWT_SECRET=

# Public base URL of the app (no trailing slash).
# Local: http://localhost:3000   Production: https://your-domain.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional shared secret Lynk.id may include in webhook requests.
# When set, the webhook checks the "x-lynk-signature" / "x-webhook-secret"
# header (or a `secret` field in the payload) and rejects mismatches.
# Leave empty to accept unsigned webhooks (payload is still logged).
LYNK_WEBHOOK_SECRET=

# Default admin account, created automatically on first run / via seed script.
ADMIN_EMAIL=admin@dowalabs.com
ADMIN_DEFAULT_PASSWORD=ChangeMe123!

# ── Default AppSettings values (used to seed the settings document) ──
# Google / Gemini Canvas link opened by active members.
DEFAULT_CANVAS_URL=https://example.com/your-google-canvas-link
# Admin WhatsApp number in international format (digits only or with +).
DEFAULT_ADMIN_WHATSAPP=628123456789
# Lynk.id payment links per package.
DEFAULT_LYNK_BASIC_URL=https://lynk.id/your-basic-link
DEFAULT_LYNK_PRO_URL=https://lynk.id/your-pro-link

# Optional branding.
NEXT_PUBLIC_BRAND_NAME=DowaLabs
